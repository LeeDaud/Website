[Unit]
Description=LeeDaud Spring Boot Backend
After=network.target mariadb.service redis.service

[Service]
Type=simple
User=root
WorkingDirectory=/root/website/runtime/backend
ExecStart=/usr/bin/java -Djava.net.preferIPv4Stack=true -Djava.net.preferIPv4Addresses=true -jar /root/website/runtime/backend/LeeDaud-server.jar --spring.profiles.active=prod --spring.config.additional-location=file:/root/website/runtime/backend/
SuccessExitStatus=143
Restart=always
RestartSec=5
Environment=TZ=Asia/Shanghai

[Install]
WantedBy=multi-user.target
