# Copy to deploy/backup.env and update values for your server.

# Backup root path
BACKUP_ROOT=/root/backup

# MySQL settings
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=leedaud
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=LeeDaud

# Optional: if exists, this file will be preferred over MYSQL_PASSWORD.
# Example content:
# [client]
# user=leedaud
# password=your_password
# host=127.0.0.1
# port=3306
MYSQL_CNF=/root/.my.cnf

# Retention policy (days)
RETENTION_DAYS=14
