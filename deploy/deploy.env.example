# Copy this file to deploy/deploy.env on the server and edit values.

# Git
BRANCH=main
SKIP_GIT_PULL=0

# Project path on server (repo root)
APP_ROOT=/root/website

# Static publish roots
WWW_ROOT=/var/www
HOME_DIST=/var/www/licheng.website
BLOG_DIST=/var/www/blog.licheng.website
CV_DIST=/var/www/cv.licheng.website
ADMIN_DIST=/var/www/admin.licheng.website

# Backend runtime
BACKEND_RUNTIME_DIR=/root/website/runtime/backend
BACKEND_JAR_NAME=LeeDaud-server.jar
BACKEND_SERVICE_NAME=leedaud-backend
BACKEND_PROFILE=prod
BACKEND_PORT=5922
BACKEND_JAVA_OPTS="-Djava.net.preferIPv4Stack=true -Djava.net.preferIPv4Addresses=true"
BACKEND_WRITE_RUNTIME_CONFIG=1
BACKEND_CONFIG_FILE=/root/website/runtime/backend/application.yml

# Backend runtime application.yml generation
BACKEND_DB_HOST=127.0.0.1
BACKEND_DB_PORT=3306
BACKEND_DB_NAME=LeeDaud
BACKEND_DB_USER=leedaud
BACKEND_DB_PASSWORD=LeeDaud@2026

BACKEND_REDIS_HOST=127.0.0.1
BACKEND_REDIS_PORT=6379
BACKEND_REDIS_PASSWORD=
BACKEND_REDIS_DATABASE=0

BACKEND_MAIL_HOST=smtp.qq.com
BACKEND_MAIL_PORT=465
BACKEND_MAIL_USER=1015976714@qq.com
BACKEND_MAIL_PASSWORD=kptvjbecjhtubffi
BACKEND_EMAIL_PERSONAL=LeeDaud
BACKEND_EMAIL_FROM=1015976714@qq.com
BACKEND_MAIL_SSL_ENABLE=true
BACKEND_MAIL_STARTTLS_ENABLE=false
BACKEND_MAIL_STARTTLS_REQUIRED=false
BACKEND_MAIL_CONNECTION_TIMEOUT_MS=5000
BACKEND_MAIL_TIMEOUT_MS=5000
BACKEND_MAIL_WRITE_TIMEOUT_MS=5000

BACKEND_JWT_SECRET=LeeDaud-jwt-secret-2026-0123456789abcdef
BACKEND_JWT_TTL=7200000
BACKEND_JWT_TOKEN_NAME=Authorization
BACKEND_VISITOR_VERIFY_CODE=123456

BACKEND_MYBATIS_MAPPER_LOCATIONS=classpath:mapper/*.xml
BACKEND_MYBATIS_ALIASES_PACKAGE=cc.leedaud.entity,cc.feitwnd.entity
BACKEND_LOG_ROOT_PACKAGE=cc

BACKEND_WEBSITE_TITLE=LeeDaud
BACKEND_WEBSITE_HOME=https://licheng.website
BACKEND_WEBSITE_ADMIN=https://admin.licheng.website
BACKEND_WEBSITE_CV=https://cv.licheng.website
BACKEND_WEBSITE_BLOG=https://blog.licheng.website

# Optional skip switches
SKIP_FRONTEND_BUILD=0
SKIP_BACKEND_BUILD=0

# Frontend build memory for Node.js on server
# Increase if build exits with code 134 (OOM), e.g. --max-old-space-size=3072
FRONTEND_NODE_OPTIONS=--max-old-space-size=2048
FRONTEND_BUILD_ARGS=--minify=esbuild

# Auto create swap on server before frontend builds (helps avoid Node OOM on small VPS)
ENABLE_AUTO_SWAP=1
SWAP_SIZE_MB=2048
SWAP_FILE_PATH=/swapfile.leedaud
