# Copy this file to deploy/deploy.env on the server and edit values.

# Git
BRANCH=main
SKIP_GIT_PULL=0

# Project path on server (repo root)
APP_ROOT=/root/website

# Static publish roots
WWW_ROOT=/var/www
HOME_DIST=/var/www/licheng.website
BLOG_DIST=/var/www/blog.licheng.website
CV_DIST=/var/www/cv.licheng.website
ADMIN_DIST=/var/www/admin.licheng.website

# Backend runtime
BACKEND_RUNTIME_DIR=/root/website/runtime/backend
BACKEND_JAR_NAME=LeeDaud-server.jar
BACKEND_SERVICE_NAME=leedaud-backend
BACKEND_PROFILE=prod
BACKEND_PORT=5922

# Optional skip switches
SKIP_FRONTEND_BUILD=0
SKIP_BACKEND_BUILD=0

# Frontend build memory for Node.js on server
# Increase if build exits with code 134 (OOM), e.g. --max-old-space-size=3072
FRONTEND_NODE_OPTIONS=--max-old-space-size=2048

# Auto create swap on server before frontend builds (helps avoid Node OOM on small VPS)
ENABLE_AUTO_SWAP=1
SWAP_SIZE_MB=2048
SWAP_FILE_PATH=/swapfile.leedaud
